{
  "appId": "com.lannkyaung.app",
  "appName": "Lann Kyaung",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "lannkyaung"
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0d0d0d",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0d0d0d"
    }
  }
}
